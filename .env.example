# ─── Contracts (Foundry) ──────────────────────────────────────────────────────
# Deployer wallet private key (becomes initial contract owner)
DEPLOYER_PRIVATE_KEY=

# Arbitrum Sepolia RPC — get free at alchemy.com or infura.io
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Optional: Arbiscan API key for contract verification
# Get free at https://arbiscan.io/apis
ARBISCAN_API_KEY=

# ─── Protocol deployment (DeployProtocol.s.sol) ──────────────────────────────
# USDC on Arbitrum Sepolia (Circle's official testnet USDC)
USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Fee distribution wallets (can all be deployer address for testnet)
TREASURY_ADDRESS=
LIQUIDITY_RESERVE=
EMERGENCY_RESERVE=

# Optional: fee collection + testnet admin setup during DeployProtocol.s.sol
FEE_COLLECTOR_ADDRESS=
# Arbitrum Sepolia: use the direct admin wallet because Safe UI does not support this testnet.
ADMIN_ADDRESS=
RESOLVER_ADDRESS=
# Arbitrum One mainnet: use real deployed Safe addresses.
ADMIN_SAFE_ADDRESS=
RESOLVER_SAFE_ADDRESS=

# ─── MVP frontend contract config (Vercel) ───────────────────────────────────
# Paste these after DeployProtocol.s.sol prints the deployed addresses.
VITE_PRONOS_ARB_SEPOLIA_FACTORY=
VITE_PRONOS_ARB_SEPOLIA_TOKEN=
VITE_PRONOS_ARB_SEPOLIA_USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
VITE_PRONOS_ARB_SEPOLIA_ADMIN_SAFE=0x0000000000000000000000000000000000000000
VITE_PRONOS_ARB_SEPOLIA_RESOLVER_SAFE=0x0000000000000000000000000000000000000000

# Future mainnet values
VITE_PRONOS_ARBITRUM_FACTORY=
VITE_PRONOS_ARBITRUM_TOKEN=
VITE_PRONOS_ARBITRUM_USDC=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
VITE_PRONOS_ARBITRUM_ADMIN_SAFE=
VITE_PRONOS_ARBITRUM_RESOLVER_SAFE=

# ─── Protocol indexer (Vercel serverless) ────────────────────────────────────
DATABASE_URL=
DATABASE_READ_URL=
MIGRATE_KEY=
CHAIN_ID=421614
FACTORY_ADDRESS=
PRONOS_FACTORY_ADDRESS=
ARB_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# Optional first-run block. Set to the deployment block if the indexer starts late.
INDEXER_START_BLOCK=
INDEXER_KEY=
CRON_SECRET=

# ─── Waitlist email (Resend) ─────────────────────────────────────────────────
# Get free API key at https://resend.com — verify pronos.io domain in dashboard
RESEND_API_KEY=

# ─── Points app (off-chain / Turnkey) ────────────────────────────────────────
# HMAC secret for signed session cookies. MUST be at least 16 chars.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# If missing, /api/points/auth/* endpoints return `session_config_missing`.
POINTS_SESSION_SECRET=

# Turnkey credentials for email-OTP auth. Get from https://app.turnkey.com
# Public + private must be a matching P-256 keypair registered in the org.
TURNKEY_ORGANIZATION_ID=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
# Optional: overrides "Pronos" in the OTP email subject / customization.
TURNKEY_APP_NAME=Pronos
# Optional: defaults to https://api.turnkey.com
# TURNKEY_API_BASE_URL=

# Client-side Turnkey bundle (Vite) — same org ID, used for IndexedDB auth.
VITE_TURNKEY_ORGANIZATION_ID=
# VITE_TURNKEY_API_BASE_URL=https://api.turnkey.com

# Comma-separated admin usernames that can reach /admin in the points app.
# Server-side check lives in _lib/points-admin.js; clients also respect
# VITE_POINTS_ADMIN_USERNAMES for UI-only nav hiding.
POINTS_ADMIN_USERNAMES=
VITE_POINTS_ADMIN_USERNAMES=

# ─── Market-generation agent ─────────────────────────────────────────────────
# Free-tier API key for football-data.org — register at
# https://www.football-data.org/client/register. Powers the soccer pipeline
# (UCL + PL + PD + SA → admin approval queue). Without this set the soccer
# generator logs a warning and skips.
FOOTBALL_DATA_API_KEY=

# Finnhub free-tier key (60 req/min). Powers the stocks pipeline
# (SPY / QQQ / DIA / TSLA / MSFT / NVDA / AAPL) AND the api_price resolver
# that settles those markets at close. Register at https://finnhub.io/register.
FINNHUB_API_KEY=

# Optional override for the Chainlink reader (defaults to Arbitrum One's
# public RPC). Set this if you're seeing 429s from arb1.arbitrum.io/rpc
# under load and want to point at an Alchemy / Infura endpoint instead.
CHAINLINK_RPC_URL=

# Banxico SIE API token. Powers the FX generator (weekly USD/MXN
# over/under) AND the api_price resolver for source='banxico-fix'.
# Register free at https://www.banxico.org.mx/SieAPIRest/service/v1/token.
# Without this set the FX generator logs a warning and skips.
BANXICO_API_TOKEN=

# ─── Legacy (Base Sepolia — PronoBet) ────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASESCAN_API_KEY=
PRONOS_BET_ADDRESS=0x9a03F59DD857856d930b12f5da63c586d824804D
# OUTCOME=1
