# ─── Contracts (Foundry) ──────────────────────────────────────────────────────
# Your deployer wallet private key (the one that calls resolve() later)
PRIVATE_KEY=

# Base Sepolia RPC — public endpoint, no changes needed
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional: Basescan API key for contract verification
# Get free at https://basescan.org/apis
BASESCAN_API_KEY=

# ─── Admin scripts ────────────────────────────────────────────────────────────
# PronoBet contract address — fill after deploying
PRONOS_BET_ADDRESS=

# Outcome for resolve script (1=Mexico, 2=Draw, 3=SouthAfrica)
# OUTCOME=1
